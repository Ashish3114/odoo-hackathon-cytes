<odoo>
    <record id="view_esg_carbon_transaction_list" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.list</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <list string="Carbon Transactions">
                <field name="name"/>
                <field name="department_id"/>
                <field name="category"/>
                <field name="date"/>
                <field name="emission_amount"/>
            </list>
        </field>
    </record>

    <record id="view_esg_carbon_transaction_form" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.form</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <form string="Carbon Transaction">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="category"/>
                        <field name="date"/>
                        <field name="emission_amount"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_carbon_transaction" model="ir.actions.act_window">
        <field name="name">Carbon Transactions</field>
        <field name="res_model">esg.carbon.transaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_esg_carbon_transaction" name="Carbon Transactions" parent="menu_esg_root" action="action_esg_carbon_transaction"/>
</odoo>