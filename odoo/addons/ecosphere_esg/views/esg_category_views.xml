<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- list View -->
    <record id="view_esg_category_list" model="ir.ui.view">
        <field name="name">esg.category.list</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_esg_category_form" model="ir.ui.view">
        <field name="name">esg.category.form</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <form string="ESG Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="type"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_esg_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">esg.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_esg_category"
        name="Categories"
        parent="menu_esg_root"
        action="action_esg_category"
        sequence="2"/>

</odoo>