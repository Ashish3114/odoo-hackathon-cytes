<odoo>
    <record id="view_esg_csr_activity_list" model="ir.ui.view">
        <field name="name">esg.csr.activity.list</field>
        <field name="model">esg.csr.activity</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="department_id"/>
                <field name="category"/>
                <field name="activity_date"/>
                <field name="participants"/>
                <field name="hours_contributed"/>
            </list>
        </field>
    </record>

    <record id="view_esg_csr_activity_form" model="ir.ui.view">
        <field name="name">esg.csr.activity.form</field>
        <field name="model">esg.csr.activity</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="category"/>
                        <field name="activity_date"/>
                        <field name="participants"/>
                        <field name="hours_contributed"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_csr_activity" model="ir.actions.act_window">
        <field name="name">CSR Activities</field>
        <field name="res_model">esg.csr.activity</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_esg_csr_activity"
              name="CSR Activities"
              parent="menu_esg_root"
              action="action_esg_csr_activity"
              sequence="60"/>
</odoo>