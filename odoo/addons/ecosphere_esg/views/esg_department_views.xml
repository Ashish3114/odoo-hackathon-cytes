<odoo>
    <record id="view_esg_department_list" model="ir.ui.view">
        <field name="name">esg.department.list</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <list string="ESG Departments">
                <field name="name"/>
                <field name="code"/>
                <field name="head"/>
                <field name="employee_count"/>
            </list>
        </field>
    </record>

    <record id="view_esg_department_form" model="ir.ui.view">
        <field name="name">esg.department.form</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <form string="ESG Department">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="head"/>
                        <field name="employee_count"/>
                        <field name="active"/>
                        <field name="total_emissions"/>
                        <field name="environment_score"/>
                        <field name="social_score"/>
                        <field name="governance_score"/>
                        <field name="esg_score" widget="progressbar"/>
                        <field name="carbon_transaction_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_department" model="ir.actions.act_window">
        <field name="name">ESG Departments</field>
        <field name="res_model">esg.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_esg_root" name="EcoSphere ESG"/>
    <menuitem id="menu_esg_department" name="Departments" parent="menu_esg_root" action="action_esg_department"/>
</odoo>
