<odoo>
    <record id="view_esg_emission_factor_list" model="ir.ui.view">
        <field name="name">esg.emission.factor.list</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="factor_value"/>
                <field name="unit"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_esg_emission_factor_form" model="ir.ui.view">
        <field name="name">esg.emission.factor.form</field>
        <field name="model">esg.emission.factor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="factor_value"/>
                        <field name="unit"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_emission_factor" model="ir.actions.act_window">
        <field name="name">Emission Factors</field>
        <field name="res_model">esg.emission.factor</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_esg_emission_factor"
              name="Emission Factors"
              parent="menu_esg_root"
              action="action_esg_emission_factor"
              sequence="40"/>
</odoo>